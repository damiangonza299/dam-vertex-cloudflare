
# ── HTML — nunca cachear (ni browser ni CDN edge)
/*
  Cache-Control: no-store

# ── CSS versionado — cachear para siempre (el ?v= invalida automáticamente)
/assets/css/*.css
  Cache-Control: public, max-age=31536000

# ── JS versionado — cachear para siempre
/assets/js/*.js
  Cache-Control: public, max-age=31536000

# ── site-version.js — NUNCA cachear (es la fuente del número de versión)
# esta regla va DESPUÉS de /assets/js/*.js para sobreescribirla
/assets/js/site-version.js
  Cache-Control: no-store

# ── Imágenes y video — cachear para siempre
/assets/img/*
  Cache-Control: public, max-age=31536000

/assets/video/*
  Cache-Control: public, max-age=31536000
